{
  "name": "@_linked/schema",
  "displayName": "Schema",
  "license": "UNLICENSED",
  "version": "1.0.4",
  "linkedPackage": true,
  "author": {
    "name": "Valentine Wilson",
    "url": "https://github.com/DiggidyDev",
    "email": "valentinewilson@gmail.com"
  },
  "main": "lib/cjs/index.js",
  "types": "dist/lincd-schema.d.ts",
  "scripts": {
    "start": "npm exec linked dev",
    "build": "yarn linked build",
    "prepublishOnly": "yarn linked build production",
    "postpublish": "npm exec linked register"
  },
  "dependencies": {
    "@_linked/core": "^2.0.1",
    "@_linked/primitives": "~1.0",
    "@_linked/react": "^1.1.0",
    "@_linked/server-utils": "~1.0",
    "@_linked/xsd": "~1.0",
    "formidable": "^3.5.4",
    "lincd-mui-base": "~1.0",
    "prism-react-renderer": "^2.4.1",
    "typescript": "^5.7.3",
    "usehooks-ts": "^2.9.1"
  },
  "devDependencies": {
    "@_linked/cli": "^1.2",
    "@types/formidable": "^3.4.5",
    "prism-react-renderer": "^2.4.1",
    "tsconfig-to-dual-package": "^1.2.0",
    "typescript-plugin-css-modules": "^5.1.0"
  },
  "module": "lib/esm/index.js",
  "exports": {
    ".": {
      "types": "./lib/esm/index.d.ts",
      "import": "./lib/esm/index.js",
      "require": "./lib/cjs/index.js"
    },
    "./*.js": {
      "types": "./lib/esm/*.d.ts",
      "import": "./lib/esm/*.js",
      "require": "./lib/cjs/*.js"
    },
    "./*": {
      "types": "./lib/esm/*.d.ts",
      "import": "./lib/esm/*.js",
      "require": "./lib/cjs/*.js"
    }
  },
  "typesVersions": {
    "*": {
      "*": [
        "lib/esm/*"
      ]
    }
  },
  "publishConfig": {
    "access": "public"
  }
}
